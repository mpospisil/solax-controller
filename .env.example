# Local developer secrets for the Solax.Worker app.
#
# Copy this file to ".env" (which is gitignored) and fill in real values. On startup the worker
# loads the nearest ".env" file into the process environment, so these reach the app whether it is
# started with `dotnet run` or the VS Code debugger. Real system/CI environment variables take
# precedence over anything set here.
#
# Keys use the ASP.NET Core convention: "__" (double underscore) separates configuration sections,
# so Solcast__ApiKey binds to the "Solcast:ApiKey" setting.

# Solcast API key (secret) -- get it from your Solcast account.
Solcast__ApiKey=your-solcast-api-key

# Optional: override non-secret Solcast settings here instead of appsettings.json if you prefer.
# Solcast__ResourceId=your-solcast-resource-id
