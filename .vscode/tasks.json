{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "dotnet",
            "args": ["build", "${workspaceFolder}/SolaxLocalController.slnx"],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": "$msCompile",
            "options": {
                "env": {
                    "DOTNET_ROOT": "${env:HOME}/.dotnet",
                    "PATH": "${env:HOME}/.dotnet:${env:PATH}"
                }
            }
        },
        {
            "label": "test",
            "type": "shell",
            "command": "dotnet",
            "args": ["test", "${workspaceFolder}/SolaxLocalController.slnx"],
            "group": { "kind": "test", "isDefault": true },
            "problemMatcher": "$msCompile",
            "options": {
                "env": {
                    "DOTNET_ROOT": "${env:HOME}/.dotnet",
                    "PATH": "${env:HOME}/.dotnet:${env:PATH}"
                }
            }
        },
        {
            "label": "run-worker",
            "type": "shell",
            "command": "dotnet",
            "args": ["run", "--project", "${workspaceFolder}/src/Solax.Worker/Solax.Worker.csproj"],
            "problemMatcher": "$msCompile",
            "options": {
                "env": {
                    "DOTNET_ROOT": "${env:HOME}/.dotnet",
                    "PATH": "${env:HOME}/.dotnet:${env:PATH}"
                }
            }
        }
    ]
}
