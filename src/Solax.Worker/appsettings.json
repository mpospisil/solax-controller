{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/solax-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "Solax": {
    "PollIntervalSeconds": 5,
    "Inverter": {
      "Host": "192.168.2.6",
      "Port": 502,
      "UnitId": 1
    },
    "EvCharger": {
      "Host": "192.168.2.10",
      "Port": 502,
      "UnitId": 1
    },
    "ChargingStrategy": {
      "NominalVoltage": 230,
      "MinChargingCurrentAmps": 6,
      "MaxChargingCurrentAmps": 20
    }
  },
  "Solcast": {
    "BaseUrl": "https://api.solcast.com.au/",
    "ResourceId": "your-solcast-resource-id",
    "RefreshInterval": "12:00:00"
  },
  "ChargeControl": {
    "Enabled": false,
    "DryRun": false,
    "NominalVoltage": 230,
    "Phases": 3,
    "MinChargingCurrentAmps": 6,
    "MaxChargingCurrentAmps": 16,
    "CurrentStepAmps": 1,
    "SurplusAverageWindow": "00:03:00",
    "CurrentChangeThresholdAmps": 1,
    "ResumeHysteresisWatts": 200,
    "BatteryFullSocPercent": 95,
    "BatteryReleaseSocPercent": 90
  }
}
